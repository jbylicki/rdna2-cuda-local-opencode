# Usage:
#   docker buildx build --target server -t llama-cpp-cuda \
#     --build-arg CUDA_ARCHS="89-real,61-virtual" \
#     -f Dockerfile.cuda .
#
#   docker compose up

ARG UBUNTU_VERSION=24.04
ARG CUDA_VERSION=12.8.1

# Default CUDA architectures: sm_89 (RTX 5060 Ti) + sm_61 (GTX 1060)
# Convert to CMake format: 89-real;61-virtual
# Override with --build-arg CUDA_ARCHS="sm_89,sm_61" or "89-real,61-virtual"
ARG CUDA_ARCHS=sm_89,sm_61

ARG BASE=nvidia/cuda:${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION}
FROM ${BASE} AS build

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        gcc-14 g++-14 build-essential cmake ninja-build git libssl-dev python3 \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

ENV CC=gcc-14 CXX=g++-14 CUDAHOSTCXX=g++-14

# Convert sm_NN format to CMake architecture format (NN-real;NN-virtual)
ARG CUDA_ARCHS
RUN set -eu; \
    ARCHS="${CUDA_ARCHS}"; \
    CMARK=""; \
    IFS=',' read -ra PARTS <<< "${ARCHS}"; \
    for p in "${PARTS[@]}"; do \
        if echo "$p" | grep -qE '^sm_'; then \
            NUM="${p#sm_}"; \
            MAJOR="${NUM:0:1}"; \
            if [ "$MAJOR" -le 7 ]; then \
                CMARK+="${NUM}-virtual;"; \
            else \
                CMARK+="${NUM}-real;"; \
            fi; \
        else \
            CMARK+="${p};"; \
        fi; \
    done; \
    echo "${CMARK%;}" > /tmp/cuda_archs.txt && cat /tmp/cuda_archs.txt

WORKDIR /app

COPY llama-cpp-turboquant/ .

ARG CUDA_ARCHS
RUN CMAKE_CUDA_ARCH=$(cat /tmp/cuda_archs.txt) && \
    cmake -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DGGML_NATIVE=OFF \
        -DGGML_CUDA=ON \
        -DGGML_BACKEND_DL=ON \
        -DGGML_CPU_ALL_VARIANTS=ON \
        -DLLAMA_BUILD_TESTS=OFF \
        -DCMAKE_CUDA_ARCHITECTURES="${CMAKE_CUDA_ARCH}" && \
    cmake --build build --config Release -j$(nproc)

# Runtime base
FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu${UBUNTU_VERSION} AS runtime

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libgomp1 curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# ─── Server target ──────────────────────────────────────────────
FROM runtime AS server

ARG CUDA_ARCHS
ENV LLAMA_ARG_HOST=0.0.0.0
WORKDIR /app

COPY --from=build /app/build/bin/llama-server .
COPY --from=build /tmp/cuda_archs.txt .

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=5s --retries=3 \
    CMD curl -fs http://localhost:8080/health || exit 1

ENTRYPOINT ["/app/llama-server"]
CMD ["--model", "/app/models/model.gguf", "--host", "0.0.0.0", "--port", "8080"]
